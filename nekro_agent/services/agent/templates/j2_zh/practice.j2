t = np.linspace(0, 2*np.pi, 100)
# 更小的系数会让图形太小，更大的系数会让图形太大
x = 16 * np.sin(t)**3
y = 13 * np.cos(t) - 5 * np.cos(2*t) - 2 * np.cos(3*t) - np.cos(4*t)

plt.figure(figsize=(6, 6))
plt.plot(x, y, 'r-')
plt.axis('equal')
plt.axis('off')

# 根据沙盒规则，文件必须保存在 ./shared/ 目录下；我当前工作在 /app，因此绝对路径会是 /app/shared/heart.png
plt.savefig('./shared/heart.png')
plt.close()

send_msg_file(_ck, './shared/heart.png')
